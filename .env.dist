# Discord Configuration
DISCORD_TOKEN=your_discord_token_here

# Binance API Configuration (Optional - leave empty to skip Binance)
# Required permissions: Enable Futures, Enable Reading
BINANCE_TOKEN=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# Bybit API Configuration (Optional - leave empty to skip Bybit)
# Required permissions: Read, Trade, WebSocket
BYBIT_TOKEN=your_bybit_api_key
BYBIT_SECRET_KEY=your_bybit_secret_key

# Telegram Bot Configuration (Optional)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_TASKIQ_DB=0

# Note: At least one exchange (Binance or Bybit) must be configured for the bot to work.
